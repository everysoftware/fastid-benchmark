BENCHMARK_FASTID_GRANT_TYPE=client_credentials
BENCHMARK_FASTID_TOKEN_URL=http://localhost:8012/api/v1/token
BENCHMARK_FASTID_CLIENT_ID=fastid-client
BENCHMARK_FASTID_CLIENT_SECRET=fastid-secret
BENCHMARK_FASTID_SCOPE="openid profile email"

BENCHMARK_KEYCLOAK_GRANT_TYPE=client_credentials
BENCHMARK_KEYCLOAK_TOKEN_URL=http://localhost:8112/realms/master/protocol/openid-connect/token
BENCHMARK_KEYCLOAK_CLIENT_ID=keycloak-client
BENCHMARK_KEYCLOAK_CLIENT_SECRET=keycloak-secret
BENCHMARK_KEYCLOAK_SCOPE="openid profile email"

BENCMARK_AUTHENTIK_GRANT_TYPE=client_credentials
BENCHMARK_AUTHENTIK_TOKEN_URL=http://localhost:9012/application/o/token/
BENCHMARK_AUTHENTIK_CLIENT_ID=authentik-client
BENCHMARK_AUTHENTIK_CLIENT_SECRET=authentik-secret
BENCHMARK_AUTHENTIK_SCOPE="openid profile email"

AUTHENTIK_WEB__THREADS=1
AUTHENTIK_WORKER__PROCESSES=1
AUTHENTIK_WORKER__THREADS=2
AUTHENTIK_POSTGRESQL__DISABLE_SERVER_SIDE_CURSORS=true
AUTHENTIK_POSTGRESQL__CONN_MAX_AGE=0

FASTID_DB_POOL_SIZE=100
FASTID_REDIS_POOL_SIZE=50
FASTID_GUNICORN_WORKER_CONNECTIONS=10000
FASTID_GUNICORN_MAX_REQUESTS=0

